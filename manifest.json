{
  "manifest_version": 3,
  "name": "Surya_Gudipati",
  "version": "1.0",
  "description": "A cyberpunk/hacker themed new tab page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "bookmarks"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": ["https://leetcode.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src 'self' https://*.youtube.com https://*.youtube-nocookie.com;"
  }
}
